# Copy this file to `.env` and fill in values. Never commit secrets.
#
# Application
APP_ENV=development
LOG_LEVEL=INFO

# Google Cloud (OCR / storage / vector DB as applicable)
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=
GCS_BUCKET_NAME=
AI_AGENT_PREFIX_GCS=adr_ai_agent

# API
API_HOST=0.0.0.0
API_PORT=8000
API_AUTH_TOKEN=change-me-to-a-secure-token

# Cloud SQL (PostgreSQL + pgvector)
CLOUDSQL_HOST=localhost
CLOUDSQL_PORT=5432
CLOUDSQL_DATABASE=adr_ai_agent
CLOUDSQL_USER=postgres
CLOUDSQL_PASSWORD=postgres

# MongoDB (feedback storage)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=adr_ai_agent
